{
    "name": "deskivo",
    "version": "1.0.0",
    "main": "app/renderer/main/index.js",
    "type": "module",
    "private": true,
    "scripts": {
        "start": "electron .",
        "dist": "electron-builder --win"
    },
    "devDependencies": {
        "drizzle-kit": "^0.31.9",
        "electron": "^40.7.0",
        "electron-builder": "^26.8.1"
    },
    "dependencies": {
        "dotenv": "^17.3.1",
        "drizzle-orm": "^0.45.1",
        "pg": "^8.20.0"
    },
    "build": {
        "appId": "deskivo.app",
        "productName": "Deskivo",
        "directories": {
            "output": "C:\\deskivo"
        },
        "files": [
            "app/**/*",
            "node_modules/**/*",
            "package.json"
        ],
        "asar": false,
        "win": {
            "target": "portable"
        }
    }
}